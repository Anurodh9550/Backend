DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

# CORS config
CORS_ALLOW_ALL_ORIGINS=True
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Database config
# Use `sqlite` for local quick start, `postgres` for production-ready setup
DB_ENGINE=postgres
POSTGRES_DB=message_chair
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432

# Redis for cache + websockets
REDIS_URL=redis://127.0.0.1:6379/1

# Admin API protection key (required for admin write/list operations)
ADMIN_API_KEY=change-this-admin-key
